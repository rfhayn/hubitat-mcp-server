# Hubitat Connection
HUBITAT_HOST=192.168.1.x        # Hub IP address on your local network
HUBITAT_APP_ID=123               # Maker API app ID (from Hubitat admin)
HUBITAT_ACCESS_TOKEN=xxx         # Maker API access token (from Hubitat admin)

# MCP Server
MCP_TRANSPORT=http               # "stdio" (local Claude Code CLI) or "http" (remote access)
MCP_HTTP_PORT=3000               # Port for HTTP transport
MCP_AUTH_TOKEN=                   # Bearer token for HTTP transport auth (auto-generated if empty)

# ngrok (optional — enables remote access from Claude mobile/web)
NGROK_AUTHTOKEN=                  # From https://dashboard.ngrok.com/authtokens
NGROK_DOMAIN=                     # Free static domain from https://dashboard.ngrok.com/domains
