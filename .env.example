# Hubitat Connection
HUBITAT_HOST=192.168.1.x
HUBITAT_APP_ID=123
HUBITAT_ACCESS_TOKEN=xxx

# MCP Server
# MCP_TRANSPORT: "stdio" (local Claude Code CLI) or "http" (remote access)
MCP_TRANSPORT=http
# MCP_HTTP_PORT: Port for HTTP transport
MCP_HTTP_PORT=3000
# MCP_AUTH_TOKEN: Bearer token for HTTP transport auth (auto-generated by setup.sh if empty)
MCP_AUTH_TOKEN=

# ngrok (optional — enables remote access from Claude mobile/web)
# Get authtoken from: https://dashboard.ngrok.com/authtokens
NGROK_AUTHTOKEN=
# Claim free static domain from: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=
